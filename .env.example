# Supabase — copie para .env.local e preencha com os dados do seu projeto.
# Painel: https://app.supabase.com → seu projeto → Project Settings → API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-public-key

# NÃO coloque a service_role key aqui (ela é secreta e só vai no back-end).
